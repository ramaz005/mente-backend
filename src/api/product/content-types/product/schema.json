{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "price_min": {
      "type": "integer"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "top",
        "leggings",
        "jumpsuit",
        "shorts",
        "rashguard"
      ]
    },
    "color": {
      "type": "string"
    },
    "description": {
      "type": "blocks"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "in_stock": {
      "type": "boolean"
    },
    "price_max": {
      "type": "integer"
    }
  }
}
